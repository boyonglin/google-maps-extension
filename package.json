{
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "lint": "eslint .",
    "format": "prettier --write \"Package/dist/**/*.js\" \"tests/**/*.js\" \"scss/**/*.scss\"",
    "format:check": "prettier --check \"Package/dist/**/*.js\" \"tests/**/*.js\" \"scss/**/*.scss\"",
    "build:css": "sass scss/popup.scss Package/css/popup.css",
    "prepare": "husky"
  },
  "lint-staged": {
    "Package/dist/**/*.js": "prettier --write",
    "tests/**/*.js": "prettier --write",
    "scss/**/*.scss": "prettier --write"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.28.3",
    "@eslint/js": "^10.0.1",
    "babel-jest": "^29.7.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "isomorphic-dompurify": "^2.30.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.7.4",
    "sass": "^1.99.0"
  }
}
